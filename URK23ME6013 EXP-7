import java.util.Scanner;

public class student {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter a string: ");
        String str = sc.nextLine();

        System.out.println("\nOriginal String: " + str);

        // Length of string
        System.out.println("Length of string: " + str.length());
        
        // Uppercase and Lowercase
        System.out.println("Uppercase: " + str.toUpperCase());
        System.out.println("Lowercase: " + str.toLowerCase());

        // Substring - Safely handle strings shorter than 5 chars
        int end = Math.min(str.length(), 5);
        System.out.println("Substring (0 to " + end + "): " + str.substring(0, end));

        // Replace
        System.out.println("Replace 'a' with '@': " + str.replace('a', '@'));

        // String comparison
        System.out.print("\nEnter another string to compare: ");
        String str2 = sc.nextLine();

        if (str.equals(str2)) {
            System.out.println("Both strings are equal.");
        } else {
            System.out.println("Both strings are not equal.");
        }

        sc.close();
    }
}
